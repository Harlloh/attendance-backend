// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AttendanceRecord {
  id                String   @id @default(cuid())
  sessionId         String
  session           Session  @relation(fields: [sessionId], references: [id])
  name              String
  stateCode         String
  queueNumber       Int
  deviceFingerprint String?
  addedByAdmin      Boolean  @default(false)
  timestamp         DateTime @default(now())

  @@unique([sessionId, stateCode])
  @@unique([sessionId, queueNumber])
  @@unique([sessionId, deviceFingerprint])
}

model LGA {
  id    String  @id @default(cuid()) // use official LGA code e.g. "OY-IBADAN-NORTH"
  name  String  @unique
  state String?

  latitude    Float? // nullable until admin sets it
  longitude   Float? // nullable until admin sets it
  radius      Int? // nullable until admin sets it
  checkInSlug String    @unique
  updatedAt   DateTime? @updatedAt
  createdAt   DateTime  @default(now())

  adminId String? @unique
  admin   Admin?  @relation(fields: [adminId], references: [id])

  sessions Session[]
}

model Admin {
  id       String @id @default(cuid())
  email    String @unique
  password String

  lga               LGA?
  sessions          Session[]
  verificationToken VerificationToken[]

  updatedAt DateTime? @updatedAt
  createdAt DateTime  @default(now())
}

model Session {
  id    String @id @default(cuid())
  lgaId String
  lga   LGA    @relation(fields: [lgaId], references: [id])

  adminId String
  admin   Admin  @relation(fields: [adminId], references: [id])

  date DateTime @default(now())

  isOpen Boolean @default(false)

  autoOpenAt  DateTime?
  autoCloseAt DateTime?

  openedAt DateTime?
  closedAt DateTime?

  attendance AttendanceRecord[]

  @@index([adminId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  adminId   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id])
}
